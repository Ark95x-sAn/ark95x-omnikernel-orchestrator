# ============================================================
# Council Ouroboros — .env.example
# Copy to .env on the runway machine; .env is gitignored.
# NEVER commit real keys. All GATED actions default OFF.
# ============================================================

# --- RUNTIME ---
ENV=development           # development | staging | production
LOG_LEVEL=INFO            # DEBUG | INFO | WARN | ERROR
QUORUM_MIN=4              # min voters to count a cycle
CONFIDENCE_FLOOR=80       # 0-100; below triggers second round
COST_CAP_DAILY_USD=10     # auto-fallback to Ollama at 80%

# --- GATE FLAGS (all OFF by default) ---
GATED_STRIPE_CHARGE=false
GATED_EMAIL_SEND=false
GATED_SOCIAL_POST=false
GATED_REPO_PUSH=false
GATED_DOMAIN_BUY=false
GATED_ACCOUNT_CREATE=false
HITL_APPROVAL_URL_BASE=https://localhost:8443/gate

# --- COUNCIL VOTERS (API keys; leave blank to skip voter) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
DASHSCOPE_API_KEY=         # Qwen
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# --- WORKERS ---
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
LANGGRAPH_BASE_URL=http://localhost:8123
GOOGLE_OAUTH_CREDENTIALS_PATH=/secrets/google-oauth.json
STRIPE_SECRET_KEY=         # GATED — only loaded if GATED_STRIPE_CHARGE=true
STRIPE_WEBHOOK_SECRET=
EMAIL_SMTP_HOST=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# --- LEARNING / MEMORY ---
CHROMA_HOST=http://chroma:8000
CHROMA_COLLECTION=ouroboros_memory
POSTGRES_URL=postgresql://ouroboros:ouroboros@postgres:5432/ouroboros
DRIFT_SIGMA_THRESHOLD=2.0   # 1.0 sensitive | 2.0 balanced | 3.0 strict
WEIGHT_LEARNING_RATE=0.05

# --- MONITORING ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERT_SMS_NUMBER=          # twilio target for GATED pings
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- DOMAIN-SPECIFIC ---
IOWA_COUNTY_LIST=Winnebago,Hancock,Cerro_Gordo,Wright,Franklin
FORECLOSURE_SCRAPE_INTERVAL_MIN=60
ATTORNEY_OUTREACH_BATCH_SIZE=10
PRODUCT_TIERS_JSON='{"T1":149,"T2":299,"T3":499,"T4_MO":2500}'
